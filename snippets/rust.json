{
  "derives": {
    "prefix": "derives",
    "body": [
      "#[derive(Debug, PartialEq, Clone$0)]"
    ],
    "description": "Common derives for a type"
  },
  "let else": {
    "prefix": "let else",
    "body": [
      "let ${1:Some}(${2:name}) = ${3:value} else {",
      "\treturn;",
      "};"
    ]
  },
  "component": {
    "prefix": "mkcmp",
    "body": [
      "#[derive(Component, Reflect, PartialEq, Debug, Clone$0)]",
      "#[reflect(Component)]"
    ],
    "description": "A Bevy component"
  },
  "component-no-reflection": {
    "prefix": "mkcmpnr",
    "body": [
      "#[derive(Component, PartialEq, Debug, Clone$0)]"
    ],
    "description": "A Bevy component without Reflect"
  },
  "component-optional-reflection": {
    "prefix": "mkcmpor",
    "body": [
      "#[derive(Component, PartialEq, Debug, Clone$0)]",
      "#[cfg_attr(feature = \"reflect\", derive(bevy_reflect::Reflect))]",
      "#[cfg_attr(feature = \"reflect\", reflect(Component))]"
    ],
    "description": "A Bevy component with Reflect gated by a 'reflect' feature"
  },
  "marker": {
    "prefix": "mkmark",
    "body": [
      "#[derive(Component)]"
    ],
    "description": "A Bevy marker component"
  },
  "resource": {
    "prefix": "mkres",
    "body": [
      "#[derive(Resource, Reflect, PartialEq, Debug, Clone$0)]",
      "#[reflect(Resource)]"
    ],
    "description": "A Bevy resource"
  },
  "message": {
    "prefix": "mkmsg",
    "body": [
      "#[derive(Message, Reflect, PartialEq, Debug, Clone$0)]",
      "#[reflect(Message)]"
    ],
    "description": "A Bevy message"
  },
  "event": {
    "prefix": "mkevt",
    "body": [
