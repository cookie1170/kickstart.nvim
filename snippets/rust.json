    "description": "A Bevy system using bevy_auto_plugin"
  },
  "plugin": {
    "prefix": "mkplug",
    "body": [
      "#[derive(AutoPlugin)]",
      "#[auto_plugin(impl_plugin_trait)]",
      "pub(super) struct Plugin;$0"
    ],
    "description": "A Bevy plugin using bevy_auto_plugin"
  },
  "plugfn": {
    "prefix": "mkplugfn",
    "body": [
      "#[derive(AutoPlugin)]",
      "pub(super) struct Plugin;",
      "",
      "#[auto_plugin(plugin = Plugin)]",
      "fn plugin(app: &mut App) {",
      "\t$0",
      "}"
    ],
    "description": "A Bevy plugin function using bevy_auto_plugin"
  }
