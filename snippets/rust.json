    ],
    "description": "A Bevy event"
  },
  "optional-reflect": {
    "prefix": "optreflect",
    "body": [
      "#[cfg_attr(feature = \"reflect\", derive(bevy_reflect::Reflect))]",
      "#[cfg_attr(feature = \"reflect\", reflect($1))]$0"
    ],
    "description": "A Reflect derive gated by a 'reflect' feature"
  },
  "observer": {
    "prefix": "mkobs",
    "body": [
